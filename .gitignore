# ==========================
# Java & Maven (构建产物)
# ==========================
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/
*.class
# 忽略打包好的 jar/war 包，只传源码
*.jar
*.war
*.ear

